{
  "type": "object",
  "description": "HillshadeLayer",
  "title": "IHillshadeLayer",
  "required": ["source"],
  "additionalProperties": false,
  "properties": {
    "source": {
      "type": "string",
      "description": "The id of the source"
    },
    "shadowColor": {
      "type": "string",
      "description": "The color of the the shadows",
