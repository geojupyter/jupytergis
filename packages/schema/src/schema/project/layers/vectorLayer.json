{
  "type": "object",
  "description": "VectorLayer",
  "title": "IVectorLayer",
  "required": ["source"],
  "additionalProperties": false,
  "definitions": {
    "_RGBA": {
      "type": "array",
      "description": "[R 0-255, G 0-255, B 0-255, A 0-1]",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4
    },
    "_ClassificationMode": {
      "type": "string",
      "enum": ["equal interval", "quantile", "jenks", "pretty", "logarithmic"]
    },
    "_StyleChannel": {
      "type": "string",
      "enum": [
        "fill-color",
        "stroke-color",
        "circle-fill-color",
        "circle-stroke-color",
        "pixel-color",
        "fill-red",
        "fill-green",
        "fill-blue",
        "pixel-red",
        "pixel-green",
        "pixel-blue",
        "fill-alpha",
        "pixel-alpha",
        "pixel-rgb",
        "stroke-width",
        "circle-radius",
        "circle-stroke-width"
      ]
    },
    "_IPredicate": {
      "oneOf": [
        {
          "type": "object",
          "description": "Filter by geometry type.",
          "required": ["type", "value"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["geometryType"] },
            "value": {
              "type": "string",
              "enum": ["Point", "LineString", "Polygon"]
            }
          }
        },
        {
          "type": "object",
          "description": "Filter by presence of a field.",
          "required": ["type", "field"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["hasField"] },
            "field": { "type": "string" }
          }
        },
        {
          "type": "object",
          "description": "Filter by exact field value (string or number).",
          "required": ["type", "field", "value"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["fieldEquals"] },
            "field": { "type": "string" },
            "value": { "oneOf": [{ "type": "string" }, { "type": "number" }] }
          }
        },
        {
          "type": "object",
          "description": "Filter by numeric field comparison.",
          "required": ["type", "field", "op", "value"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["fieldCompare"] },
            "field": { "type": "string" },
            "op": { "type": "string", "enum": [">", "<", ">=", "<=", "!="] },
            "value": { "type": "number" }
          }
        },
        {
          "type": "object",
          "description": "Filter by numeric field range (inclusive).",
          "required": ["type", "field", "min", "max"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["between"] },
            "field": { "type": "string" },
            "min": { "type": "number" },
            "max": { "type": "number" }
          }
        }
      ]
    },
    "_ITransform": {
      "oneOf": [
        {
          "type": "object",
          "description": "KDE heatmap transform. Density output addressed as '$density'.",
          "required": ["type", "radius", "blur"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["kde"] },
            "radius": { "type": "number", "minimum": 1 },
            "blur": { "type": "number", "minimum": 0 },
            "weightField": { "type": "string" }
          }
        },
        {
          "type": "object",
          "description": "Cluster transform. Aggregates nearby points into centroids.",
          "required": ["type", "radius"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["cluster"] },
            "radius": { "type": "number", "minimum": 1 }
          }
        }
      ]
    },
    "_IScale": {
      "oneOf": [
        {
          "type": "object",
          "description": "Maps a numeric field through a named color palette to RGBA.",
          "required": ["scheme", "params"],
          "additionalProperties": false,
          "properties": {
            "scheme": { "type": "string", "enum": ["colorRamp"] },
            "params": {
              "type": "object",
              "required": ["name", "nShades", "mode", "reverse", "fallback"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "domain": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 2,
                  "maxItems": 2
                },
                "nShades": { "type": "number" },
                "mode": { "$ref": "#/definitions/_ClassificationMode" },
                "reverse": { "type": "boolean" },
                "fallback": { "$ref": "#/definitions/_RGBA" },
                "colorStops": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["stop", "color"],
                    "additionalProperties": false,
                    "properties": {
                      "stop": { "type": "number" },
                      "color": { "$ref": "#/definitions/_RGBA" }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "description": "Maps discrete field values to colors sampled from a named palette.",
          "required": ["scheme", "params"],
          "additionalProperties": false,
          "properties": {
            "scheme": { "type": "string", "enum": ["categorical"] },
            "params": {
              "type": "object",
              "required": ["colorRamp", "fallback"],
              "additionalProperties": false,
              "properties": {
                "colorRamp": { "type": "string" },
                "nShades": { "type": "number" },
                "reverse": { "type": "boolean" },
                "fallback": { "$ref": "#/definitions/_RGBA" },
                "colorStops": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["stop", "color"],
                    "additionalProperties": false,
                    "properties": {
                      "stop": {
                        "oneOf": [{ "type": "string" }, { "type": "number" }]
                      },
                      "color": { "$ref": "#/definitions/_RGBA" }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "description": "Maps a numeric field to a numeric output (radius, width, sub-channel value).",
          "required": ["scheme", "params"],
          "additionalProperties": false,
          "properties": {
            "scheme": { "type": "string", "enum": ["scalar"] },
            "params": {
              "type": "object",
              "required": ["domain", "range", "mode", "nStops", "fallback"],
              "additionalProperties": false,
              "properties": {
                "domain": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 2,
                  "maxItems": 2
                },
                "range": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 2,
                  "maxItems": 2
                },
                "mode": { "$ref": "#/definitions/_ClassificationMode" },
                "nStops": { "type": "number" },
                "fallback": { "type": "number" },
                "scalarStops": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["stop", "output"],
                    "additionalProperties": false,
                    "properties": {
                      "stop": { "type": "number" },
                      "output": { "type": "number" }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "description": "Fixed RGBA color regardless of feature data.",
          "required": ["scheme", "params"],
          "additionalProperties": false,
          "properties": {
            "scheme": { "type": "string", "enum": ["constant_rgba"] },
            "params": {
              "type": "object",
              "required": ["value"],
              "additionalProperties": false,
              "properties": {
                "value": { "$ref": "#/definitions/_RGBA" }
              }
            }
          }
        },
        {
          "type": "object",
          "description": "Fixed numeric value regardless of feature data.",
          "required": ["scheme", "params"],
          "additionalProperties": false,
          "properties": {
            "scheme": { "type": "string", "enum": ["constant_num"] },
            "params": {
              "type": "object",
              "required": ["value"],
              "additionalProperties": false,
              "properties": {
                "value": { "type": "number" }
              }
            }
          }
        },
        {
          "type": "object",
          "description": "Passes the field value through unchanged.",
          "required": ["scheme"],
          "additionalProperties": false,
          "properties": {
            "scheme": { "type": "string", "enum": ["identity"] }
          }
        },
        {
          "type": "object",
          "description": "Evaluates an expression against one or more input fields (reserved).",
          "required": ["scheme", "params"],
          "additionalProperties": false,
          "properties": {
            "scheme": { "type": "string", "enum": ["expression"] },
            "params": {
              "type": "object",
              "required": ["expr", "fallback"],
              "additionalProperties": false,
              "properties": {
                "expr": { "type": "string" },
                "fallback": {
                  "oneOf": [
                    { "type": "number" },
                    { "$ref": "#/definitions/_RGBA" }
                  ]
                }
              }
            }
          }
        }
      ]
    },
    "_IMapping": {
      "type": "object",
      "description": "A (scale, channels) pair: one scale drives one or more output channels.",
      "required": ["scale", "channels"],
      "additionalProperties": false,
      "properties": {
        "scale": { "$ref": "#/definitions/_IScale" },
        "channels": {
          "type": "array",
          "description": "Target output channel names.",
          "items": { "$ref": "#/definitions/_StyleChannel" },
          "minItems": 1
        }
      }
    },
    "_IEncodingRule": {
      "type": "object",
      "description": "Maps optional input fields to one or more (scale, channels) pairs.",
      "required": ["id", "mappings"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "Stable UUID." },
        "fields": {
          "type": "array",
          "description": "Input field name(s). Absent for constant rules.",
          "items": { "type": "string" }
        },
        "mappings": {
          "type": "array",
          "description": "(scale, channels) pairs sharing these input fields.",
          "items": { "$ref": "#/definitions/_IMapping" },
          "minItems": 1
        },
        "when": {
          "type": "array",
          "description": "Guard predicates for this rule.",
          "items": { "$ref": "#/definitions/_IPredicate" }
        },
        "whenOp": {
          "type": "string",
          "enum": ["all", "any"],
          "description": "Logical combinator for when predicates. Defaults to 'all'."
        }
      }
    },
    "_IGrammarLayer": {
      "type": "object",
      "description": "One independent rendering pipeline on a source.",
      "required": ["id", "rules"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "Stable UUID." },
        "preprocess": {
          "type": "array",
          "description": "Render-side transforms (KDE, cluster) applied before encoding rules.",
          "items": { "$ref": "#/definitions/_ITransform" }
        },
        "rules": {
          "type": "array",
          "description": "Encoding rules compiled into a flat-style expression for this layer.",
          "items": { "$ref": "#/definitions/_IEncodingRule" }
        },
        "when": {
          "type": "array",
          "description": "Guard predicates applied to every rule in this layer.",
          "items": { "$ref": "#/definitions/_IPredicate" }
        },
        "whenOp": {
          "type": "string",
          "enum": ["all", "any"],
          "description": "Logical combinator for when predicates. Defaults to 'all'."
        }
      }
    }
  },
  "properties": {
    "source": {
      "type": "string",
      "description": "The id of the source"
    },
    "color": {
      "type": "object",
      "description": "DEPRECATED. Legacy OpenLayers FlatStyle cache. New files should not set this; symbologyState is the source of truth. Retained only so that legacy .jGIS files can be migrated on load.",
      "default": {}
    },
    "opacity": {
      "type": "number",
      "description": "The opacity of the the object",
      "default": 1,
      "multipleOf": 0.1,
      "minimum": 0,
      "maximum": 1
    },
    "symbologyState": {
      "type": "object",
      "description": "The symbology configuration. This is the single source of truth for how the layer is rendered; the OpenLayers style is derived from it on the fly.",
      "properties": {
        "method": {
          "type": "string",
          "enum": ["color", "radius"],
          "default": "color"
        },
        "colorRamp": {
          "type": "string",
          "default": "viridis"
        },
        "nClasses": {
          "type": "number",
          "default": 9.0
        },
        "reverseRamp": {
          "type": "boolean",
          "default": false
        },
        "mode": {
          "type": "string",
          "default": "equal interval",
          "enum": [
            "quantile",
            "equal interval",
            "jenks",
            "pretty",
            "logarithmic"
          ]
        },
        "vmin": {
          "type": "number",
          "description": "Minimum value for color mapping"
        },
        "vmax": {
          "type": "number",
          "description": "Maximum value for color mapping"
        },
        "fallbackColor": {
          "type": "array",
          "description": "RGBA fallback color for features with no matching category or outside the gradient range",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        },
        "strokeFollowsFill": {
          "type": "boolean",
          "description": "Whether the stroke color follows the fill color expression",
          "default": false
        },
        "fillColor": {
          "type": "array",
          "description": "Manual RGBA fill color. Used for Single Symbol, and as the base fill for Categorized when no stops are defined.",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        },
        "strokeColor": {
          "type": "array",
          "description": "Manual RGBA stroke color",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        },
        "strokeWidth": {
          "type": "number",
          "description": "Stroke width in pixels",
          "default": 1.25
        },
        "radius": {
          "type": "number",
          "description": "Circle radius in pixels for point geometries (Single Symbol, and the base for Graduated radius)",
          "default": 5
        },
        "joinStyle": {
          "type": "string",
          "enum": ["bevel", "round", "miter"],
          "default": "round"
        },
        "capStyle": {
          "type": "string",
          "enum": ["butt", "round", "square"],
          "default": "round"
        },
        "geometryType": {
          "type": "string",
          "enum": ["fill", "circle", "line"],
          "description": "The type of geometry."
        },
        "stopsOverride": {
          "type": "array",
          "description": "User-customized color stops that override the computed classification. Saved only when the user manually edits stop colors in the dialog.",
          "items": {
            "type": "object",
            "properties": {
              "value": {},
              "color": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 4,
                "maxItems": 4
              }
            }
          }
        },
        "rules": {
          "type": "array",
          "description": "Legacy top-level encoding rules (backward compatibility). New files should use layers.",
          "items": { "$ref": "#/definitions/_IEncodingRule" }
        },
        "layers": {
          "type": "array",
          "description": "Grammar rendering layers. Each layer is an independent rendering pipeline with optional preprocess transforms and encoding rules.",
          "items": { "$ref": "#/definitions/_IGrammarLayer" }
        }
      },
      "additionalProperties": false,
      "default": {
        "method": "color",
        "colorRamp": "viridis",
        "nClasses": 9,
        "mode": "equal interval"
      }
    }
  }
}
