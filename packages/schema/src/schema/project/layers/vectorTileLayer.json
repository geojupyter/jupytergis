{
  "type": "object",
  "description": "VectorTileLayer",
  "title": "IVectorTileLayer",
  "required": ["source"],
  "additionalProperties": false,
  "properties": {
    "source": {
      "type": "string",
      "description": "The id of the source"
    },
    "color": {
      "type": "object",
      "description": "The color of the the object",
      "default": {}
    },
    "opacity": {
      "type": "number",
      "description": "The opacity of the the object",
      "default": 1,
      "multipleOf": 0.1,
      "minimum": 0,
      "maximum": 1
    },
    "symbologyState": {
      "type": "object",
      "description": "The state of the symbology panel options",
      "properties": {
        "method": {
          "type": "string",
          "enum": ["color", "radius"],
          "default": "color"
        },
        "colorRamp": {
          "type": "string",
          "default": "viridis"
        },
        "nClasses": {
          "type": "string",
          "default": "9"
        },
        "mode": {
          "type": "string",
          "default": "equal interval",
          "enum": [
            "quantile",
            "equal interval",
            "jenks",
            "pretty",
            "logarithmic"
          ]
        },
        "vmin": {
          "type": "number",
          "description": "Minimum value for color mapping"
        },
        "vmax": {
          "type": "number",
          "description": "Maximum value for color mapping"
        },
        "fallbackColor": {
          "type": "array",
          "description": "RGBA fallback color for features with no matching category or outside the gradient range",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        },
        "strokeFollowsFill": {
          "type": "boolean",
          "description": "Whether the stroke color follows the fill color expression",
          "default": false
        },
        "rules": {
          "type": "array",
          "description": "Legacy top-level encoding rules (backward compatibility). New files should use layers.",
          "items": {
            "$ref": "project/symbology.json#/definitions/IEncodingRule"
          }
        },
        "layers": {
          "type": "array",
          "description": "Grammar rendering layers. Each layer is an independent rendering pipeline with optional preprocess transforms and encoding rules.",
          "items": {
            "$ref": "project/symbology.json#/definitions/IGrammarLayer"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
