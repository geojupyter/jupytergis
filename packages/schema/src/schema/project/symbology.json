{
  "type": "object",
  "description": "SymbologyState",
  "title": "ISymbologyState",
  "definitions": {
    "RGBA": {
      "type": "array",
      "description": "[R 0-255, G 0-255, B 0-255, A 0-1]",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4
    },
    "ClassificationMode": {
      "type": "string",
      "enum": ["equal interval", "quantile", "jenks", "pretty", "logarithmic"]
    },
    "RGBAChannel": {
      "type": "string",
      "enum": [
        "fill-color",
        "stroke-color",
        "circle-fill-color",
        "circle-stroke-color",
        "pixel-color"
      ]
    },
    "UInt8Channel": {
      "type": "string",
      "enum": [
        "fill-red",
        "fill-green",
        "fill-blue",
        "pixel-red",
        "pixel-green",
        "pixel-blue"
      ]
    },
    "UNormChannel": {
      "type": "string",
      "enum": ["fill-alpha", "pixel-alpha"]
    },
    "VirtualChannel": {
      "type": "string",
      "enum": ["pixel-rgb"]
    },
    "PosFloatChannel": {
      "type": "string",
      "enum": ["stroke-width", "circle-radius", "circle-stroke-width"]
    },
    "Encoding": {
      "title": "Encoding",
      "description": "Any supported output style channel for vector or raster symbology.",
      "anyOf": [
        { "$ref": "#/definitions/RGBAChannel" },
        { "$ref": "#/definitions/UInt8Channel" },
        { "$ref": "#/definitions/UNormChannel" },
        { "$ref": "#/definitions/VirtualChannel" },
        { "$ref": "#/definitions/PosFloatChannel" }
      ]
    },
    "ICompareOp": {
      "type": "string",
      "enum": [">", "<", ">=", "<=", "!="]
    },
    "IGeometryTypePredicate": {
      "type": "object",
      "title": "IGeometryTypePredicate",
      "description": "Filter by geometry type.",
      "required": ["type", "value"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "geometryType" },
        "value": {
          "type": "string",
          "enum": ["Point", "LineString", "Polygon"]
        }
      }
    },
    "IHasFieldPredicate": {
      "type": "object",
      "title": "IHasFieldPredicate",
      "description": "Filter by presence of a field.",
      "required": ["type", "field"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "hasField" },
        "field": { "type": "string" }
      }
    },
    "IFieldEqualsPredicate": {
      "type": "object",
      "title": "IFieldEqualsPredicate",
      "description": "Filter by exact field value (string or number).",
      "required": ["type", "field", "value"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "fieldEquals" },
        "field": { "type": "string" },
        "value": { "oneOf": [{ "type": "string" }, { "type": "number" }] }
      }
    },
    "IFieldComparePredicate": {
      "type": "object",
      "title": "IFieldComparePredicate",
      "description": "Filter by numeric field comparison.",
      "required": ["type", "field", "op", "value"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "fieldCompare" },
        "field": { "type": "string" },
        "op": { "$ref": "#/definitions/ICompareOp" },
        "value": { "type": "number" }
      }
    },
    "IBetweenPredicate": {
      "type": "object",
      "title": "IBetweenPredicate",
      "description": "Filter by numeric field range (inclusive).",
      "required": ["type", "field", "min", "max"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "between" },
        "field": { "type": "string" },
        "min": { "type": "number" },
        "max": { "type": "number" }
      }
    },
    "IPredicate": {
      "title": "IPredicate",
      "description": "Predicate union used for conditional rule/layer guards (the `when` field).",
      "oneOf": [
        { "$ref": "#/definitions/IGeometryTypePredicate" },
        { "$ref": "#/definitions/IHasFieldPredicate" },
        { "$ref": "#/definitions/IFieldEqualsPredicate" },
        { "$ref": "#/definitions/IFieldComparePredicate" },
        { "$ref": "#/definitions/IBetweenPredicate" }
      ]
    },
    "IKDETransform": {
      "type": "object",
      "title": "IKDETransform",
      "description": "KDE heatmap transform. Density output addressed as '$density'.",
      "required": ["type", "radius", "blur"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "kde" },
        "radius": { "type": "number", "minimum": 1 },
        "blur": { "type": "number", "minimum": 0 },
        "weightField": { "type": "string" }
      }
    },
    "IClusterTransform": {
      "type": "object",
      "title": "IClusterTransform",
      "description": "Cluster transform. Aggregates nearby points into centroids.",
      "required": ["type", "radius"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "cluster" },
        "radius": { "type": "number", "minimum": 1 }
      }
    },
    "ITransform": {
      "title": "ITransform",
      "description": "Preprocessing transform union applied before encoding rules.",
      "oneOf": [
        { "$ref": "#/definitions/IKDETransform" },
        { "$ref": "#/definitions/IClusterTransform" }
      ]
    },
    "IColorRampScale": {
      "type": "object",
      "title": "IColorRampScale",
      "description": "Maps a numeric field through a named color palette to RGBA.",
      "required": ["scheme", "params"],
      "additionalProperties": false,
      "properties": {
        "scheme": { "const": "colorRamp" },
        "params": {
          "type": "object",
          "title": "IColorRampScaleParams",
          "description": "Parameters controlling color-ramp classification and fallback behavior.",
          "required": ["name", "nShades", "mode", "reverse", "fallback"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "domain": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2
            },
            "nShades": { "type": "number" },
            "mode": { "$ref": "#/definitions/ClassificationMode" },
            "reverse": { "type": "boolean" },
            "fallback": { "$ref": "#/definitions/RGBA" },
            "colorStops": {
              "type": "array",
              "items": {
                "type": "object",
                "title": "IColorStop",
                "description": "Explicit stop-to-color mapping entry.",
                "required": ["stop", "color"],
                "additionalProperties": false,
                "properties": {
                  "stop": { "type": "number" },
                  "color": { "$ref": "#/definitions/RGBA" }
                }
              }
            }
          }
        }
      }
    },
    "ICategoricalScale": {
      "type": "object",
      "title": "ICategoricalScale",
      "description": "Maps discrete field values to colors sampled from a named palette.",
      "required": ["scheme", "params"],
      "additionalProperties": false,
      "properties": {
        "scheme": { "const": "categorical" },
        "params": {
          "type": "object",
          "title": "ICategoricalScaleParams",
          "description": "Parameters controlling category-to-color mapping.",
          "required": ["colorRamp", "fallback"],
          "additionalProperties": false,
          "properties": {
            "colorRamp": { "type": "string" },
            "nShades": { "type": "number" },
            "reverse": { "type": "boolean" },
            "fallback": { "$ref": "#/definitions/RGBA" },
            "colorStops": {
              "type": "array",
              "items": {
                "type": "object",
                "title": "ICategoricalColorStop",
                "description": "Discrete value-to-color mapping entry.",
                "required": ["stop", "color"],
                "additionalProperties": false,
                "properties": {
                  "stop": {
                    "oneOf": [{ "type": "string" }, { "type": "number" }]
                  },
                  "color": { "$ref": "#/definitions/RGBA" }
                }
              }
            }
          }
        }
      }
    },
    "IScalarScale": {
      "type": "object",
      "title": "IScalarScale",
      "description": "Maps a numeric field to a numeric output (radius, width, sub-channel value).",
      "required": ["scheme", "params"],
      "additionalProperties": false,
      "properties": {
        "scheme": { "const": "scalar" },
        "params": {
          "type": "object",
          "title": "IScalarScaleParams",
          "description": "Parameters controlling scalar interpolation and fallback behavior.",
          "required": ["domain", "range", "mode", "nStops", "fallback"],
          "additionalProperties": false,
          "properties": {
            "domain": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2
            },
            "range": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2
            },
            "fallback": { "type": "number" },
            "scalarStops": {
              "type": "array",
              "items": {
                "type": "object",
                "title": "IScalarStop",
                "description": "Explicit input stop to output value mapping.",
                "required": ["stop", "output"],
                "additionalProperties": false,
                "properties": {
                  "stop": { "type": "number" },
                  "output": { "type": "number" }
                }
              }
            }
          }
        }
      }
    },
    "IConstantRGBAScale": {
      "type": "object",
      "title": "IConstantRGBAScale",
      "description": "Fixed RGBA color regardless of feature data.",
      "required": ["scheme", "params"],
      "additionalProperties": false,
      "properties": {
        "scheme": { "const": "constant_rgba" },
        "params": {
          "type": "object",
          "title": "IConstantRGBAParams",
          "description": "Constant RGBA payload.",
          "required": ["value"],
          "additionalProperties": false,
          "properties": {
            "value": { "$ref": "#/definitions/RGBA" }
          }
        }
      }
    },
    "IConstantNumScale": {
      "type": "object",
      "title": "IConstantNumScale",
      "description": "Fixed numeric value regardless of feature data.",
      "required": ["scheme", "params"],
      "additionalProperties": false,
      "properties": {
        "scheme": { "const": "constant_num" },
        "params": {
          "type": "object",
          "title": "IConstantNumParams",
          "description": "Constant numeric payload.",
          "required": ["value"],
          "additionalProperties": false,
          "properties": {
            "value": { "type": "number" }
          }
        }
      }
    },
    "IIdentityScale": {
      "type": "object",
      "title": "IIdentityScale",
      "description": "Passes the field value through unchanged.",
      "required": ["scheme"],
      "additionalProperties": false,
      "properties": {
        "scheme": { "const": "identity" }
      }
    },
    "IExpressionScale": {
      "type": "object",
      "title": "IExpressionScale",
      "description": "Evaluates an expression against one or more input fields (reserved).",
      "required": ["scheme", "params"],
      "additionalProperties": false,
      "properties": {
        "scheme": { "const": "expression" },
        "params": {
          "type": "object",
          "title": "IExpressionScaleParams",
          "description": "Expression source and fallback output value.",
          "required": ["expr", "fallback"],
          "additionalProperties": false,
          "properties": {
            "expr": { "type": "string" },
            "fallback": {
              "oneOf": [{ "type": "number" }, { "$ref": "#/definitions/RGBA" }]
            },
            "language": {
              "type": "string",
              "enum": ["vega", "python"],
              "default": "vega",
              "description": "Expression language. 'vega' for TS/JS expressions, 'python' for Python expressions compiled via py2vega."
            }
          }
        }
      }
    },
    "IScale": {
      "title": "IScale",
      "description": "Scale union that maps input values to styled outputs.",
      "oneOf": [
        { "$ref": "#/definitions/IColorRampScale" },
        { "$ref": "#/definitions/ICategoricalScale" },
        { "$ref": "#/definitions/IScalarScale" },
        { "$ref": "#/definitions/IConstantRGBAScale" },
        { "$ref": "#/definitions/IConstantNumScale" },
        { "$ref": "#/definitions/IIdentityScale" },
        { "$ref": "#/definitions/IExpressionScale" }
      ]
    },
    "IMapping": {
      "type": "object",
      "title": "IMapping",
      "description": "A (scale, channels) pair: one scale drives one or more output channels.",
      "required": ["scale", "channels"],
      "additionalProperties": false,
      "properties": {
        "scale": { "$ref": "#/definitions/IScale" },
        "channels": {
          "type": "array",
          "description": "Target output channel names.",
          "items": { "$ref": "#/definitions/Encoding" },
          "minItems": 1
        }
      }
    },
    "IEncodingRule": {
      "type": "object",
      "title": "IEncodingRule",
      "description": "Maps optional input fields to one or more (scale, channels) pairs.",
      "required": ["id", "mappings"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "Stable UUID." },
        "fields": {
          "type": "array",
          "description": "Input field name(s). Absent for constant rules.",
          "items": { "type": "string" }
        },
        "mappings": {
          "type": "array",
          "description": "(scale, channels) pairs sharing these input fields.",
          "items": { "$ref": "#/definitions/IMapping" },
          "minItems": 1
        },
        "when": {
          "type": "array",
          "description": "Guard predicates for this rule.",
          "items": { "$ref": "#/definitions/IPredicate" }
        },
        "whenOp": {
          "type": "string",
          "enum": ["all", "any"],
          "description": "Logical combinator for when predicates. Defaults to 'all'."
        }
      }
    },
    "IGrammarLayer": {
      "type": "object",
      "title": "IGrammarLayer",
      "description": "One independent rendering pipeline on a source.",
      "required": ["id", "rules"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "Stable UUID." },
        "preprocess": {
          "type": "array",
          "description": "Render-side transforms (KDE, cluster) applied before encoding rules.",
          "items": { "$ref": "#/definitions/ITransform" }
        },
        "rules": {
          "type": "array",
          "description": "Encoding rules compiled into a flat-style expression for this layer.",
          "items": { "$ref": "#/definitions/IEncodingRule" }
        },
        "when": {
          "type": "array",
          "description": "Guard predicates applied to every rule in this layer.",
          "items": { "$ref": "#/definitions/IPredicate" }
        },
        "whenOp": {
          "type": "string",
          "enum": ["all", "any"],
          "description": "Logical combinator for when predicates. Defaults to 'all'."
        }
      }
    }
  }
}
