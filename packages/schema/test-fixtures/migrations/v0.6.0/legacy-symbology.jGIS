      "parameters": {
        "opacity": 1,
        "source": "source-id",
        "symbologyState": {
          "fillColor": [
            0.0,
            255.0,
            0.0,
            1.0
          ],
          "geometryType": "circle",
          "radius": 4.5,
          "renderType": "Single Symbol",
          "strokeColor": [
            0.0,
            0.0,
            0.0,
            1.0
          ]
        }
      },
      "type": "VectorLayer",
      "visible": true
    },
    "vector-fill-id": {
      "name": "Fill Layer",
      "parameters": {
        "opacity": 1,
        "source": "source-id",
        "symbologyState": {
          "fillColor": [
            255.0,
            0.0,
            0.0,
            1.0
          ],
          "geometryType": "fill",
          "renderType": "Single Symbol",
          "strokeColor": [
            0.0,
            0.0,
            0.0,
            1.0
          ],
          "strokeWidth": 2.0
        }
      },
      "type": "VectorLayer",
      "visible": true
    },
    "vector-line-id": {
      "name": "Line Layer",
      "parameters": {
        "opacity": 1,
        "source": "source-id",
        "symbologyState": {
          "geometryType": "line",
          "renderType": "Single Symbol",
          "strokeColor": [
            0.0,
            0.0,
            255.0,
            1.0
          ],
          "strokeWidth": 1.5
        }
      },
      "type": "VectorLayer",
      "visible": true
