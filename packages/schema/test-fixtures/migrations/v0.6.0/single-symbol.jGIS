{
  "annotations": {},
  "layerTree": ["layer-id"],
  "layers": {
    "layer-id": {
      "name": "Fill Layer",
      "parameters": {
        "opacity": 1,
        "source": "source-id",
        "symbologyState": {
          "layers": [
            {
              "id": "test-uuid",
              "rules": [
                {
                  "id": "test-uuid",
                  "mappings": [
                    {
                      "scale": { "scheme": "constant_rgba", "params": { "value": [255, 0, 0, 1] } },
                      "channels": ["fill-color", "circle-fill-color"]
                    },
                    {
                      "scale": { "scheme": "constant_rgba", "params": { "value": [0, 0, 0, 1] } },
                      "channels": ["stroke-color", "circle-stroke-color"]
                    },
                    {
                      "scale": { "scheme": "constant_num", "params": { "value": 2 } },
                      "channels": ["stroke-width", "circle-stroke-width"]
                    },
                    {
                      "scale": { "scheme": "constant_num", "params": { "value": 5 } },
                      "channels": ["circle-radius"]
                    }
                  ]
                }
              ]
            }
          ]
        }
      },
      "type": "VectorLayer",
      "visible": true
    }
  },
  "metadata": {},
  "options": {
    "bearing": 0,
    "latitude": 0,
    "longitude": 0,
    "pitch": 0,
    "projection": "EPSG:3857",
    "zoom": 4
  },
  "schemaVersion": "0.6.0",
  "sources": {
    "source-id": {
      "name": "Source",
      "parameters": { "path": "data.geojson" },
      "type": "GeoJSONSource"
    }
  }
}
