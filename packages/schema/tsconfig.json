{
  "extends": "../../tsconfigbase.json",
  "compilerOptions": {
    "outDir": "lib",
    "rootDir": "src",
    "paths": {
      "@/*": ["./*"]
    },
    "plugins": [
      { "transform": "typescript-transform-paths" },
      { "transform": "typescript-transform-paths", "afterDeclarations": true }
    ]
  },
  "include": [
    "src/**/*",
    "src/processing/_generated/*.json",
    "src/schema/**/*.json",
    "src/_interface/*.json"
  ],
  "exclude": ["**/*.spec.ts"]
}
