{
  "name": "@jupytergis/jupytergis-qgis",
  "version": "0.16.0-beta.5",
  "description": "JupyterGIS QGIS extension.",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension"
  ],
  "homepage": "https://github.com/geojupyter/jupytergis",
  "bugs": {
    "url": "https://github.com/geojupyter/jupytergis/issues"
  },
  "license": "BSD-3-Clause",
  "author": "JupyterGIS contributors",
  "files": [
    "lib/**/*.{d.ts,eot,gif,html,jpg,js,js.map,json,png,svg,woff2,ttf}",
    "schema/*.json",
    "style/**/*.{css,js,eot,gif,html,jpg,json,png,svg,woff2,ttf}"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "repository": {
    "type": "git",
    "url": "https://github.com/geojupyter/jupytergis.git"
  },
  "scripts": {
    "build": "pnpm run build:lib && pnpm run build:labextension:dev",
    "build:prod": "pnpm run clean && pnpm run build:lib:prod && pnpm run build:labextension",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "build:lib": "tsc --sourceMap",
    "build:lib:prod": "tsc",
    "build:dev": "pnpm run build",
    "clean": "pnpm run clean:lib",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "clean:lintcache": "rimraf .eslintcache .stylelintcache",
    "clean:labextension": "rimraf jupytergis_qgis/labextension jupytergis_qgis/_version.py",
    "clean:all": "pnpm run clean:lib && pnpm run clean:labextension && pnpm run clean:lintcache",
    "eslint": "pnpm run eslint:check -- --fix",
    "eslint:check": "eslint . --cache --ext .ts,.tsx",
    "install:extension": "pnpm run build",
    "lint": "pnpm run stylelint && pnpm run prettier && pnpm run eslint",
    "lint:check": "pnpm run stylelint:check && pnpm run prettier:check && pnpm run eslint:check",
    "prettier": "pnpm run prettier:base -- --write",
    "prettier:base": "prettier \"**/*{.ts,.tsx,.js,.jsx,.css,.json,.md}\"",
    "prettier:check": "pnpm run prettier:base -- --check",
    "stylelint": "pnpm run stylelint:check -- --fix",
    "stylelint:check": "stylelint --cache \"style/**/*.css\"",
    "watch": "run-p watch:src watch:labextension",
    "watch:src": "tsc -w --sourceMap",
    "watch:labextension": "jupyter labextension watch ."
  },
  "dependencies": {
    "@jupyter/collaborative-drive": "^4.1.2 || ^5.0.0-alpha.0",
    "@jupytergis/base": "^0.16.0-beta.5",
    "@jupytergis/jupytergis-core": "^0.16.0-beta.5",
    "@jupytergis/schema": "^0.16.0-beta.5",
    "@jupyterlab/application": "^4.6",
    "@jupyterlab/apputils": "^4.6",
    "@jupyterlab/coreutils": "^6.6",
    "@jupyterlab/docregistry": "^4.6",
    "@jupyterlab/filebrowser": "^4.6",
    "@jupyterlab/launcher": "^4.6",
    "@jupyterlab/mainmenu": "^4.6",
    "@jupyterlab/services": "^7.6",
    "@jupyterlab/translation": "^4.6",
    "@jupyterlab/ui-components": "^4.6",
    "@lumino/messaging": "^2.0.0",
    "@lumino/widgets": "^2.0.0",
    "react": "^18.0.1"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.5",
    "css-loader": "^6.7.1",
    "mkdirp": "^1.0.3",
    "npm-run-all": "^4.1.5",
    "rimraf": "^3.0.2",
    "typescript": "^5",
    "yjs": "^13.5.0"
  },
  "sideEffects": [
    "style/*.css",
    "style/index.js"
  ],
  "styleModule": "style/index.js",
  "publishConfig": {
    "access": "public"
  },
  "jupyterlab": {
    "discovery": {
      "server": {
        "managers": [
          "pip"
        ],
        "base": {
          "name": "jupytergis_qgis"
        }
      }
    },
    "extension": true,
    "schemaDir": "schema",
    "outputDir": "jupytergis_qgis/labextension",
    "sharedPackages": {
      "@jupytergis/base": {
        "singleton": true,
        "bundled": false
      },
      "@jupytergis/schema": {
        "singleton": true,
        "bundled": false
      },
      "@jupytergis/jupytergis-core": {
        "singleton": true,
        "bundled": false
      },
      "@jupyter/docprovider": {
        "singleton": true,
        "bundled": false
      }
    }
  }
}
