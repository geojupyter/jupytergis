{
  "name": "jupytergis-ui-tests",
  "version": "1.0.0",
  "description": "JupyterGIS Integration Tests",
  "private": true,
  "scripts": {
    "start": "JGIS_EXPOSE_MAPS=1 jupyter lab --config jupyter_server_test_config.py",
    "start:lite": "cd ../dist && python -m http.server -b 127.0.0.1 8000",
    "test": "playwright test --workers 1 --browser chromium",
    "test:local": "playwright test --ignore-snapshots --workers 1",
    "test:lite": "playwright test tests/lite.spec.ts --workers 1 --config playwright-lite.config.js --browser chromium",
    "test:locallite": "playwright test tests/lite.spec.ts --ignore-snapshots --workers 1 --config playwright-lite.config.js",
    "test:update": "playwright test --update-snapshots --browser chromium",
    "test:updatelite": "pnpm run test:lite -- --update-snapshots",
    "test:debug": "PWDEBUG=1 playwright test --workers 1"
  },
  "devDependencies": {
    "@jupyterlab/galata": "^5.6.0-rc.0",
    "@playwright/test": "^1.57.0",
    "@types/klaw-sync": "^6.0.1"
  },
  "dependencies": {
    "klaw-sync": "^6.0.0"
  }
}
